# Copy to .env and fill in values: cp .env.example .env

# Dashboard (required when HERMES_DASHBOARD=1 on a non-loopback bind)
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=willow
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
# Session signing key — generate with: openssl rand -hex 32
HERMES_DASHBOARD_BASIC_AUTH_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# LLM
OPENROUTER_API_KEY=

# Deploy / tooling
DENO_DEPLOY_TOKEN=
VERCEL_TOKEN=
GITHUB_TOKEN=
