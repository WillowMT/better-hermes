# Copy to .env and fill in values: cp .env.example .env

# Dashboard (required when HERMES_DASHBOARD=1 on a non-loopback bind)
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=willow
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
# Session signing key — generate with: openssl rand -hex 32
HERMES_DASHBOARD_BASIC_AUTH_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# LLM
OPENROUTER_API_KEY=

# Web search (Exa — https://exa.ai)
EXA_API_KEY=

# Deploy / tooling (also set in /opt/data/.env — loaded into shells at runtime)
DENO_DEPLOY_TOKEN=
VERCEL_TOKEN=
GITHUB_TOKEN=
# gh reads GH_TOKEN; auto-mirrored from GITHUB_TOKEN when unset

# Cloudflare (wrangler — https://developers.cloudflare.com/workers/wrangler/)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Turso (also set in /opt/data/.env — loaded into shells at runtime)
# TURSO_API_TOKEN — Platform API token for `turso` CLI (turso db list, create, etc.)
TURSO_API_TOKEN=
# TURSO_DATABASE_URL / TURSO_AUTH_TOKEN — libSQL connection for apps and client SDKs
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Cloud (gcloud config persists in /opt/data/.config/gcloud on the volume)
# Optional: path to a service account JSON inside the container/volume
# GOOGLE_APPLICATION_CREDENTIALS=/opt/data/gcp-service-account.json
